# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored — never commit it.

aws_region  = "ap-southeast-2"
profile     = "work-account"

db_name     = "bankdb"
db_username = "changeme"
db_password = "changeme"

ami_id             = "ami-0b3c832b6b7289e44"
key_pair           = "aws_key"
ec2_instance_type  = "t3.micro"
image_uri          = "187740755858.dkr.ecr.ap-southeast-2.amazonaws.com/myproject/banking:1.1.3"

jwt_secret         = "changeme"
jwt_expiration     = "86400000"
hibernate_ddl_auto = "update"

# Your own IP in CIDR form, e.g. "203.0.113.10/32" — never default this to a real IP in committed files.
allowed_ssh_cidr = "203.0.113.10/32"
